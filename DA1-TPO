        <line x1="270" y1="58" x2="510" y2="58" stroke="var(--uml-iface-stroke)"/>
        <text x="280" y="76" font-family="Inter,sans-serif" font-size="12">+ exportar(ficha)</text>
        <text x="280" y="94" font-family="Inter,sans-serif" font-size="12">+ getFormato(): String</text>
        <rect x="20" y="155" width="230" height="98" rx="3" fill="var(--uml-ctx)" stroke="var(--uml-ctx-stroke)" stroke-width="1.3"/>
        <text x="135" y="175" text-anchor="middle" font-family="Inter,sans-serif" font-size="14" font-weight="700">FichaMedica</text>
